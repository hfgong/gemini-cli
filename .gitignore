# API keys and secrets
.env
.env~

# gemini-cli settings
# We want to keep the .gemini in the root of the repo and ignore any .gemini
# in subdirectories. In our root .gemini we want to allow for version control
# for subcommands.
**/.gemini/
!/.gemini/
.gemini/*
!.gemini/config.yaml
!.gemini/commands/
!.gemini/skills/
!.gemini/settings.json

# Note: .gemini-clipboard/ is NOT in gitignore so Gemini can access pasted images

# Dependency directory
node_modules
bower_components

# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo

# Ignore built ts files
dist

# Root-level build artifacts in packages
packages/*/test-setup.js
packages/*/test-setup.js.map
packages/*/test-setup.d.ts
packages/*/*.tgz
packages/*/index.js
packages/*/index.js.map
packages/*/index.d.ts
packages/*/vitest.config.js
packages/*/vitest.config.js.map
packages/*/vitest.config.d.ts
evals/vitest.config.js
evals/vitest.config.js.map
evals/vitest.config.d.ts
integration-tests/vitest.config.js
integration-tests/vitest.config.js.map
integration-tests/vitest.config.d.ts
integration-tests/globalSetup.js
integration-tests/globalSetup.js.map
integration-tests/globalSetup.d.ts
integration-tests/test-helper.js
integration-tests/test-helper.js.map
integration-tests/test-helper.d.ts
integration-tests/test-mcp-server.js
integration-tests/test-mcp-server.js.map
integration-tests/test-mcp-server.d.ts
evals/test-helper.js
evals/test-helper.js.map
evals/test-helper.d.ts
evals/app-test-helper.js
evals/app-test-helper.js.map
evals/app-test-helper.d.ts

# Generated snapshot files from .js tests
packages/*/src/**/__snapshots__/*.snap.svg
packages/*/src/**/__snapshots__/*.js.snap

# In-place TypeScript build artifacts (tsc output alongside .ts sources)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/a2a-server/src/**/*.js
packages/a2a-server/src/**/*.js.map
packages/a2a-server/src/**/*.d.ts
packages/*/examples/**/*.js
packages/*/examples/**/*.js.map
packages/*/examples/**/*.d.ts
packages/devtools/client/**/*.js
packages/devtools/client/**/*.js.map
packages/devtools/client/**/*.d.ts
evals/**/*.js
evals/**/*.js.map
evals/**/*.d.ts
integration-tests/**/*.js
integration-tests/**/*.js.map
integration-tests/**/*.d.ts
scripts/**/*.js
scripts/**/*.js.map
scripts/**/*.d.ts

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
packages/core/src/generated/
packages/devtools/src/_client-assets.ts
.integration-tests/
packages/vscode-ide-companion/*.vsix
packages/cli/download-ripgrep*/

# GHA credentials
gha-creds-*.json

# Log files
patch_output.log
gemini-debug.log

.genkit
.gemini-clipboard/
.eslintcache
evals/logs/

# Local artifacts
docs/manual-test-drive-chat-logs.html
packages/cli/*.tgz
packages/cli/package.json.bak
